# Environment Variables Example File
# Copy this file to .env.local and update values as needed

# Frontend API endpoints
VITE_API_URL=https://your-production-api.com
VITE_API_URL_DEV=http://localhost:5001

# Server-side email settings (for api/send-email.ts in Vercel/Node environment)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_TO_EMAIL=your-email@example.com
